{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "stream",
	"globalDependencies": [
		".env*"
	],
	"globalEnv": [
		"NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
		"CLERK_SECRET_KEY",
		"DATABASE_URL"
	],
	"tasks": {
		"build": {
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"tsc": {
			"dependsOn": [
				"^tsc"
			]
		},
		"migrate": {
			"dependsOn": [
				"^migrate"
			]
		},
		"generate": {
			"dependsOn": [
				"^generate"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"dev:turbo": {
			"cache": false,
			"persistent": true
		}
	}
}