{
	"extends": "@opencited/typescript-config/nextjs.json",
	"compilerOptions": {
		"plugins": [
			{
				"name": "next"
			}
		],
		"strictNullChecks": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"]
		},
		"ignoreDeprecations": "6.0"
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"next-env.d.ts",
		"next.config.js",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
