{
	"name": "opencited",
	"private": true,
	"scripts": {
		"build": "dotenv -e .env.local -- turbo run build",
		"dev": "dotenv -e .env.local -- turbo run dev",
		"migrate": "dotenv -e .env.local -- turbo run migrate",
		"generate": "dotenv -e .env.local -- turbo run generate",
		"dev:turbo": "dotenv -e .env.local -- turbo run dev:turbo",
		"lint": "dotenv -e .env.local -- biome lint --write . --unsafe",
		"lint-ci": "biome lint .",
		"tsc": "dotenv -e .env.local -- turbo run tsc",
		"format": "biome format --write .",
		"prepare": "husky",
		"commit": "git add . && czg",
		"clean": "find . -name node_modules -o -name .next -o -name .turbo -o -name dist -type d -prune | xargs rm -rf"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"dotenv-cli": "catalog:",
		"husky": "9.1.7",
		"shadcn": "catalog:",
		"turbo": "2.9.6",
		"typescript": "catalog:"
	},
	"engines": {
		"node": "24.14.1",
		"bun": "1.3.10"
	},
	"volta": {
		"node": "24.14.1",
		"bun": "1.3.10"
	},
	"packageManager": "bun@1.3.10",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"next": "16.2.3",
			"react": "19.2.5",
			"react-dom": "19.2.5",
			"@types/node": "25.6.0",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"typescript": "6.0.2",
			"@biomejs/biome": "2.4.11",
			"dotenv-cli": "11.0.0",
			"shadcn": "4.2.0",
			"@clerk/nextjs": "7.1.0",
			"tailwindcss": "4.2.2",
			"@tailwindcss/cli": "4.2.2",
			"@tailwindcss/postcss": "4.2.2",
			"postcss": "8.5.9",
			"autoprefixer": "10.5.0",
			"class-variance-authority": "0.7.1",
			"clsx": "2.1.1",
			"tailwind-merge": "3.5.0",
			"tailwindcss-animate": "1.0.7",
			"@radix-ui/react-label": "2.1.8",
			"@radix-ui/react-slot": "1.2.4",
			"zod": "4.3.6",
			"@trpc/server": "11.16.0",
			"@trpc/client": "11.16.0",
			"@trpc/tanstack-react-query": "11.16.0",
			"@tanstack/react-query": "5.99.0",
			"drizzle-orm": "1.0.0-beta.21",
			"@neondatabase/serverless": "1.0.2",
			"dotenv": "17.4.2",
			"drizzle-kit": "1.0.0-beta.21",
			"tsx": "4.21.0",
			"fast-xml-parser": "5.6.0",
			"ink": "7.0.0",
			"bun-types": "1.3.12",
			"motion": "12.38.0"
		}
	},
	"config": {
		"commitizen": {
			"czConfig": "./.commitlintrc.cjs"
		}
	}
}
