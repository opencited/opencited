{
	"name": "opencited",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "dotenv -e .env -- biome lint --write . --unsafe",
		"lint-ci": "biome lint .",
		"tsc": "turbo run tsc",
		"format": "biome format --write .",
		"prepare": "husky",
		"commit": "git add . && czg"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"dotenv-cli": "catalog:",
		"husky": "9.1.7",
		"shadcn": "catalog:",
		"turbo": "2.9.6",
		"typescript": "catalog:"
	},
	"engines": {
		"node": "24.14.1",
		"bun": "1.3.10"
	},
	"volta": {
		"node": "24.14.1",
		"bun": "1.3.10"
	},
	"packageManager": "bun@1.3.10",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"next": "16.2.3",
			"react": "19.2.5",
			"react-dom": "19.2.5",
			"@types/node": "25.6.0",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"typescript": "6.0.2",
			"@biomejs/biome": "2.4.11",
			"dotenv-cli": "11.0.0",
			"shadcn": "4.2.0",
			"@clerk/nextjs": "7.1.0"
		}
	},
	"config": {
		"commitizen": {
			"czConfig": "./.commitlintrc.cjs"
		}
	}
}
