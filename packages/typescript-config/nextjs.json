{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./base.json",
	"compilerOptions": {
		"plugins": [
			{
				"name": "next"
			}
		],
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": true,
		"jsx": "preserve",
		"noEmit": true,
		"strict": true,
		"resolveJsonModule": true,
		"incremental": true,
		"declaration": false,
		"declarationMap": false
	},
	"exclude": ["node_modules", ".next", ".turbo"]
}
